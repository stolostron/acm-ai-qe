{
  "mcpServers": {
    "acm-ui": {
      "command": "python",
      "args": ["-m", "acm_ui_mcp_server.main"],
      "cwd": "../../mcp/acm-ui-mcp-server"
    },
    "jira": {
      "command": "python",
      "args": ["-m", "jira_mcp_server.main"],
      "cwd": "../../mcp/jira-mcp-server",
      "timeout": 60
    },
    "jenkins": {
      "command": "bash",
      "args": ["-c", "cd ../../mcp/jenkins-mcp && exec python jenkins_mcp_server.py"],
      "timeout": 60
    },
    "polarion": {
      "command": "uvx",
      "args": [
        "--with", "polarion-mcp", "python",
        "../../mcp/polarion/polarion-mcp-wrapper.py"
      ],
      "cwd": "../../mcp/polarion",
      "env": {
        "POLARION_BASE_URL": "https://polarion.engineering.redhat.com/polarion"
      },
      "timeout": 90
    },
    "neo4j-rhacm": {
      "command": "uvx",
      "args": [
        "--with", "fastmcp<3",
        "mcp-neo4j-cypher",
        "--db-url", "bolt://localhost:7687",
        "--username", "neo4j",
        "--password", "rhacmgraph",
        "--read-only"
      ],
      "timeout": 60
    }
  }
}
