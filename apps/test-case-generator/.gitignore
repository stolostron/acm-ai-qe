# Run artifacts
runs/*/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/

# Session traces (generated at runtime)
.claude/traces/

# Local settings (machine-specific, not committed)
.claude/settings.local.json

# MCP config (generated by setup.sh, contains credentials)
.mcp.json

# IDE
.idea/
.vscode/

# OS
.DS_Store
