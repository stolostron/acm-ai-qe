{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://z-stream-analysis/schemas/analysis-results.schema.json",
  "title": "Z-Stream Analysis Results (v3.9)",
  "description": "Schema for analysis-results.json produced by systematic AI analysis of Jenkins pipeline failures with environment oracle, source-of-truth validation, assertion extraction, cluster investigation, feature grounding, graduated infra scoring, causal link verification, and 12-layer diagnostic investigation",
  "type": "object",
  "required": ["per_test_analysis", "summary", "investigation_phases_completed"],
  "additionalProperties": true,
  "properties": {
    "analysis_metadata": {
      "type": "object",
      "description": "Metadata about the analysis session",
      "properties": {
        "jenkins_url": { "type": "string" },
        "analyzed_at": { "type": "string" },
        "analyzer": { "type": "string", "default": "z-stream-analysis" },
        "analyzer_version": { "type": "string", "default": "3.9.0" },
        "investigation_framework": {
          "type": "string",
          "enum": ["5-phase-systematic", "legacy"],
          "default": "5-phase-systematic"
        },
        "build_result": {
          "type": "string",
          "enum": ["SUCCESS", "UNSTABLE", "FAILURE", "ABORTED", "NOT_BUILT"]
        },
        "branch": { "type": "string" },
        "run_directory": { "type": "string" }
      }
    },
    "investigation_phases_completed": {
      "type": "array",
      "description": "List of investigation phases completed (A, B, C, D, E)",
      "items": {
        "type": "string",
        "enum": ["A", "B", "C", "D", "E"]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "mcp_queries_executed": {
      "type": "array",
      "description": "MCP tool queries executed during investigation",
      "items": {
        "type": "object",
        "properties": {
          "tool": {
            "type": "string",
            "description": "MCP tool name (e.g., mcp__acm-ui__set_acm_version)"
          },
          "query": {
            "type": "string",
            "description": "Query or parameters passed to the tool"
          },
          "success": {
            "type": "boolean",
            "description": "Whether the query succeeded"
          },
          "result_summary": {
            "type": "string",
            "description": "Brief summary of the result"
          }
        },
        "required": ["tool", "success"]
      }
    },
    "cross_test_correlations": {
      "type": "object",
      "description": "Patterns detected across multiple failing tests",
      "properties": {
        "shared_selectors": {
          "type": "object",
          "description": "Selectors that appear in multiple failing tests",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "shared_components": {
          "type": "object",
          "description": "Backend components that appear in multiple failures",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "shared_feature_areas": {
          "type": "object",
          "description": "Feature areas with multiple failures",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "pattern_type": {
          "type": "string",
          "enum": ["single_selector_failure", "single_component_failure", "feature_wide_issue", "infrastructure_wide", "no_pattern", "mixed_patterns"],
          "description": "Dominant pattern type detected"
        },
        "root_cause_affects_count": {
          "type": "integer",
          "description": "Number of tests affected by the root cause"
        }
      }
    },
    "cluster_investigation": {
      "type": "object",
      "description": "Cluster investigation results from targeted component diagnostics (v3.0)",
      "properties": {
        "landscape": {
          "type": "object",
          "description": "High-level cluster state snapshot",
          "properties": {
            "managed_cluster_count": { "type": "integer" },
            "managed_cluster_statuses": { "type": "object" },
            "operator_statuses": { "type": "object" },
            "degraded_operators": { "type": "array", "items": { "type": "string" } },
            "resource_pressure": { "type": "object" },
            "multiclusterhub_status": { "type": "string" }
          }
        },
        "component_diagnostics": {
          "type": "array",
          "description": "Targeted diagnostics for specific components",
          "items": {
            "type": "object",
            "properties": {
              "component_name": { "type": "string" },
              "subsystem": { "type": "string" },
              "deployment_status": { "type": "string", "enum": ["Available", "Degraded", "Unavailable", "Missing"] },
              "desired_replicas": { "type": "integer" },
              "ready_replicas": { "type": "integer" },
              "pods": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string" },
                    "status": { "type": "string" },
                    "restart_count": { "type": "integer" },
                    "ready": { "type": "boolean" }
                  }
                }
              }
            }
          }
        },
        "infrastructure_signals": {
          "type": "array",
          "description": "Infrastructure issues detected during cluster investigation",
          "items": { "type": "string" }
        },
        "backend_failure_signals": {
          "type": "array",
          "description": "Backend component failures that may cause UI test failures",
          "items": {
            "type": "object",
            "properties": {
              "component": { "type": "string" },
              "issue": { "type": "string" },
              "affected_feature_area": { "type": "string" }
            }
          }
        }
      }
    },
    "cluster_investigation_summary": {
      "type": "object",
      "description": "Summary of cluster re-authentication and tiered investigation results",
      "properties": {
        "cluster_reauth_status": {
          "type": "string",
          "enum": ["authenticated", "failed", "skipped"],
          "description": "Whether cluster re-authentication succeeded in Stage 2"
        },
        "investigation_mode": {
          "type": "string",
          "enum": ["live", "snapshot_only"],
          "description": "Whether investigation used live cluster access or snapshot data only"
        },
        "tier_0_health": {
          "type": "object",
          "description": "Tier 0 health snapshot results",
          "properties": {
            "mch_status": { "type": "string" },
            "degraded_operators": { "type": "array", "items": { "type": "string" } },
            "resource_pressure": { "type": "object" },
            "non_healthy_pods_count": { "type": "integer" }
          }
        },
        "component_health_overview": {
          "type": "array",
          "description": "Per-feature-area component health from Tier 1",
          "items": {
            "type": "object",
            "properties": {
              "feature_area": { "type": "string" },
              "component": { "type": "string" },
              "status": { "type": "string" },
              "restart_count": { "type": "integer" },
              "key_finding": { "type": "string" }
            }
          }
        },
        "prerequisite_summary": {
          "type": "array",
          "description": "Prerequisite check results across all feature areas",
          "items": {
            "type": "object",
            "properties": {
              "feature_area": { "type": "string" },
              "prerequisite": { "type": "string" },
              "met": { "type": ["boolean", "null"] },
              "tests_affected": { "type": "integer" }
            }
          }
        }
      }
    },
    "cascading_failure_analysis": {
      "type": "object",
      "description": "Analysis of cascading failures via Knowledge Graph",
      "properties": {
        "analysis_performed": {
          "type": "boolean",
          "description": "Whether cascading failure analysis was performed"
        },
        "root_cause_component": {
          "type": "string",
          "description": "The component identified as the root cause"
        },
        "root_cause_subsystem": {
          "type": "string",
          "description": "The subsystem of the root cause component"
        },
        "dependent_components": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Components that depend on the root cause"
        },
        "tests_affected_by_cascade": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Tests affected by the cascading failure"
        },
        "knowledge_graph_query": {
          "type": "string",
          "description": "The Cypher query used to detect cascading"
        }
      }
    },
    "per_test_analysis": {
      "type": "array",
      "description": "Individual analysis for each failed test",
      "items": {
        "type": "object",
        "required": ["test_name", "classification", "confidence", "evidence_sources"],
        "properties": {
          "test_name": {
            "type": "string",
            "description": "Full name of the failed test case",
            "minLength": 1
          },
          "test_file": {
            "type": "string",
            "description": "Path to the test file"
          },
          "class_name": {
            "type": "string",
            "description": "Test class or suite name"
          },
          "classification": {
            "type": "string",
            "enum": ["PRODUCT_BUG", "AUTOMATION_BUG", "INFRASTRUCTURE", "MIXED", "UNKNOWN", "NO_BUG", "FLAKY"],
            "description": "Definitive classification of the failure"
          },
          "classification_path": {
            "type": "string",
            "enum": ["A", "B1", "B2"],
            "description": "Which decision path was used (A=selector mismatch, B1=timeout/infra, B2=JIRA investigation)"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Confidence score (0.0 to 1.0)"
          },
          "evidence_sources": {
            "type": "array",
            "description": "Evidence sources supporting the classification (minimum 2 required)",
            "minItems": 2,
            "items": {
              "type": "object",
              "required": ["source", "finding"],
              "properties": {
                "source": {
                  "type": "string",
                  "description": "Source of evidence (e.g., console_search, timeline_evidence, console_log, mcp_query)"
                },
                "finding": {
                  "type": "string",
                  "description": "What was found from this source"
                },
                "tier": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 3,
                  "description": "Evidence tier (1=definitive, 2=strong, 3=supportive)"
                }
              }
            }
          },
          "ruled_out_alternatives": {
            "type": "array",
            "description": "Alternative classifications that were ruled out",
            "items": {
              "type": "object",
              "required": ["classification", "reason"],
              "properties": {
                "classification": {
                  "type": "string",
                  "enum": ["PRODUCT_BUG", "AUTOMATION_BUG", "INFRASTRUCTURE", "MIXED", "FLAKY", "UNKNOWN", "NO_BUG"]
                },
                "reason": {
                  "type": "string",
                  "description": "Why this classification was ruled out"
                }
              }
            }
          },
          "reasoning": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "properties": {
                  "summary": { "type": "string" },
                  "evidence": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "conclusion": { "type": "string" }
                }
              }
            ],
            "description": "Analysis reasoning. Prefer structured object form with summary/evidence/conclusion. String accepted for backward compatibility."
          },
          "root_cause": {
            "type": "string",
            "description": "Root cause of the failure"
          },
          "root_cause_layer": {
            "type": "integer",
            "minimum": 1,
            "maximum": 12,
            "description": "Infrastructure layer where root cause was found (1=Compute, 2=Control Plane, 3=Network, 4=Storage, 5=Configuration, 6=Authentication, 7=Authorization, 8=API/CRD/Webhook, 9=Operator, 10=Cross-Cluster, 11=Data Flow, 12=UI). Set by investigation agent (v3.8)"
          },
          "root_cause_layer_name": {
            "type": "string",
            "enum": [
              "Compute / Scheduling",
              "Control Plane / State Store",
              "Network / Connectivity",
              "Storage / Data Persistence",
              "Configuration / Desired State",
              "Authentication / Identity",
              "Authorization / RBAC",
              "API / CRD / Webhook",
              "Operator / Reconciliation",
              "Cross-Cluster / Hub-Spoke",
              "Data Flow / Content Integrity",
              "UI / Plugin / Rendering"
            ],
            "description": "Human-readable name of the root cause layer (v3.8)"
          },
          "investigation_steps_taken": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Layer-by-layer investigation steps taken with per-layer verdicts (v3.8). Example: 'Layer 12: Console pods Running, plugins registered -> HEALTHY'"
          },
          "cause_owner": {
            "type": "string",
            "description": "WHO caused the issue at the root cause layer -- e.g., 'product operator', 'external/manual', 'test code', 'platform' (v3.8)"
          },
          "verification_status": {
            "type": "string",
            "enum": ["verified_in_group", "split_from_group", "individually_investigated"],
            "description": "How this test was verified during group investigation (v3.9). verified_in_group = passed 4-point check, group result applies. split_from_group = failed a verification check, investigated individually. individually_investigated = never in a group."
          },
          "error": {
            "type": "object",
            "properties": {
              "message": { "type": "string" },
              "type": { "type": "string" },
              "stack_trace": { "type": "string" }
            }
          },
          "recommended_fix": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "properties": {
                  "action": { "type": "string" },
                  "steps": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "owner": { "type": "string" }
                }
              }
            ],
            "description": "Fix recommendation. Prefer structured object form with action/steps/owner. String accepted for backward compatibility."
          },
          "jira_correlation": {
            "type": "object",
            "description": "JIRA correlation results for this test",
            "properties": {
              "search_performed": {
                "type": "boolean",
                "description": "Whether JIRA search was performed"
              },
              "related_issues": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Related JIRA issue keys"
              },
              "match_confidence": {
                "type": "string",
                "enum": ["high", "medium", "low", "none"],
                "description": "Confidence of JIRA match"
              }
            }
          },
          "owner": {
            "type": "string",
            "description": "Team responsible for the fix"
          },
          "priority": {
            "type": "string",
            "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW"]
          },
          "jira_component": {
            "type": "string",
            "description": "JIRA component for tracking"
          },
          "related_files": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Related files for investigation"
          },
          "mixed_components": {
            "type": "array",
            "description": "For MIXED classification: breakdown of individual issues",
            "items": {
              "type": "object",
              "properties": {
                "classification": {
                  "type": "string",
                  "enum": ["PRODUCT_BUG", "AUTOMATION_BUG", "INFRASTRUCTURE"]
                },
                "issue": { "type": "string" },
                "evidence": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "owner": { "type": "string" }
              },
              "required": ["classification", "issue"]
            }
          },
          "feature_area": {
            "type": "string",
            "description": "Feature area under test (e.g., GRC, Search, CLC, Observability, Virtualization, Automation, Application, Console, Infrastructure, RBAC)"
          },
          "is_cascading_hook_failure": {
            "type": "boolean",
            "description": "True if this is an after-all/after-each hook that failed as a consequence of a prior test failure (v3.2)",
            "default": false
          },
          "blank_page_detected": {
            "type": "boolean",
            "description": "True if the test failed because the page rendered blank (no-js / empty body) due to a missing prerequisite (v3.2)",
            "default": false
          },
          "failure_mode_category": {
            "type": "string",
            "enum": ["render_failure", "element_missing", "data_incorrect", "timeout_general", "assertion_logic", "server_error", "unknown"],
            "description": "Categorized failure mode for causal link verification (v3.3). data_incorrect = page rendered but showed wrong data; element_missing = selector not found; render_failure = page didn't load"
          },
          "assertion_analysis": {
            "type": "object",
            "description": "Extracted assertion values from the error message (v3.3). Present when the error contains expected vs actual data comparisons.",
            "properties": {
              "has_data_assertion": { "type": "boolean" },
              "assertion_type": {
                "type": "string",
                "enum": ["count_mismatch", "value_mismatch", "content_missing", "state_mismatch", "property_missing"]
              },
              "expected": { "type": ["string", "null"] },
              "actual": { "type": ["string", "null"] },
              "raw_assertion": { "type": "string" }
            }
          },
          "backend_cross_check": {
            "type": "object",
            "description": "Backend cross-check results (Phase B7) - detects UI failures caused by backend problems",
            "properties": {
              "performed": { "type": "boolean" },
              "backend_caused_ui_failure": { "type": "boolean" },
              "failing_components": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Backend components that are failing"
              },
              "evidence": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Evidence of backend causing UI failure"
              },
              "overrides_path_a": {
                "type": "boolean",
                "description": "If true, routes to Path B2 instead of Path A"
              }
            }
          },
          "prerequisite_analysis": {
            "type": "object",
            "description": "Prerequisite analysis from feature playbooks (Phase B8)",
            "properties": {
              "feature_area": { "type": "string" },
              "all_prerequisites_met": { "type": ["boolean", "null"] },
              "unmet_prerequisites": {
                "type": "array",
                "items": { "type": "string" }
              },
              "matched_failure_mode": {
                "type": "object",
                "properties": {
                  "path_id": { "type": "string" },
                  "description": { "type": "string" },
                  "suggested_classification": { "type": "string" },
                  "confidence": { "type": "number" }
                }
              }
            }
          },
          "playbook_investigation": {
            "type": "object",
            "description": "Playbook failure path investigation results (Phase B8)",
            "properties": {
              "failure_path_id": { "type": "string" },
              "failure_path_description": { "type": "string" },
              "steps_executed": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "step": { "type": "string" },
                    "command": { "type": "string" },
                    "result": { "type": "string" },
                    "matched_expectation": { "type": "boolean" }
                  }
                }
              },
              "path_confirmed": { "type": "boolean" },
              "suggested_classification": { "type": "string" },
              "confidence": { "type": "number" }
            }
          },
          "cluster_investigation_detail": {
            "type": "object",
            "description": "Per-test cluster investigation details (tiered investigation)",
            "properties": {
              "tier_reached": {
                "type": "integer",
                "minimum": 0,
                "maximum": 4,
                "description": "Highest investigation tier reached (0-4)"
              },
              "key_findings": {
                "type": "array",
                "items": { "type": "string" }
              },
              "commands_run": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "command": { "type": "string" },
                    "output_summary": { "type": "string" }
                  }
                }
              }
            }
          },
          "feature_context": {
            "type": "object",
            "description": "Feature context from Phase E (Knowledge Graph + JIRA)",
            "properties": {
              "subsystem": { "type": "string" },
              "components_involved": {
                "type": "array",
                "items": { "type": "string" }
              },
              "feature_story": { "type": "string" },
              "feature_description": { "type": "string" },
              "acceptance_criteria_summary": { "type": "string" },
              "linked_prs": {
                "type": "array",
                "items": { "type": "string" }
              },
              "por_reference": { "type": ["string", "null"] },
              "knowledge_graph_context": {
                "type": "object",
                "properties": {
                  "subsystem_queried": { "type": "boolean" },
                  "component_dependencies": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "failure_in_dependency": { "type": "boolean" }
                }
              },
              "source": {
                "type": "string",
                "description": "How context was obtained (e.g., knowledge_graph+jira, jira_only, knowledge_graph_only)"
              }
            }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "description": "Overall summary of all test failures",
      "required": ["by_classification"],
      "properties": {
        "total_tests": { "type": "integer", "minimum": 0 },
        "passed_count": { "type": "integer", "minimum": 0 },
        "failed_count": { "type": "integer", "minimum": 0 },
        "total_failures": { "type": "integer", "minimum": 0 },
        "pass_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Test pass rate as a percentage (0-100)"
        },
        "by_classification": {
          "type": "object",
          "properties": {
            "PRODUCT_BUG": { "type": "integer", "minimum": 0 },
            "AUTOMATION_BUG": { "type": "integer", "minimum": 0 },
            "INFRASTRUCTURE": { "type": "integer", "minimum": 0 },
            "MIXED": { "type": "integer", "minimum": 0 },
            "UNKNOWN": { "type": "integer", "minimum": 0 },
            "NO_BUG": { "type": "integer", "minimum": 0 },
            "FLAKY": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "cascading_hook_failures": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of after-all/after-each hook failures classified as NO_BUG due to cascading from prior test failures (v3.2)"
        },
        "blank_page_failures": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of tests that failed due to blank page (no-js) caused by missing prerequisites (v3.2)"
        },
        "data_assertion_failures": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of tests with failure_mode_category=data_incorrect — page rendered but showed wrong data (v3.3)"
        },
        "feature_area_health": {
          "type": "object",
          "description": "Per-feature-area health scores from graduated infrastructure analysis (v3.3)",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "health_score": { "type": "number", "minimum": 0, "maximum": 1 },
              "infrastructure_signal": {
                "type": "string",
                "enum": ["definitive", "strong", "moderate", "none"]
              },
              "degraded_components": {
                "type": "array",
                "items": { "type": "string" }
              },
              "total_restart_count": { "type": "integer" }
            }
          }
        },
        "overall_classification": {
          "type": "string",
          "enum": ["PRODUCT_BUG", "AUTOMATION_BUG", "INFRASTRUCTURE", "MIXED", "UNKNOWN", "NO_BUG", "FLAKY", "REQUIRES_INVESTIGATION"]
        },
        "overall_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "priority_order": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "test": { "type": "string" },
              "priority": { "type": "string" },
              "reason": { "type": "string" },
              "classification": { "type": "string" }
            }
          }
        }
      }
    },
    "jira_correlation": {
      "type": "object",
      "description": "Overall JIRA correlation results",
      "required": ["search_performed"],
      "properties": {
        "search_performed": {
          "type": "boolean",
          "description": "Whether JIRA search was performed"
        },
        "queries_executed": {
          "type": "integer",
          "description": "Number of JIRA queries executed"
        },
        "related_issues_found": {
          "type": "array",
          "items": { "type": "string" },
          "description": "All related JIRA issues found"
        },
        "known_issue_matches": {
